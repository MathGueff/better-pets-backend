{
    "semi": false,
    "tabWidth": 2,
    "bracketSameLine": true,
    "endOfLine": "lf",
    "singleQuote": true,
    "useTabs": false,
    "objectWrap": "collapse",
    "bracketSpacing": true,
    "trailingComma": "none",
    "arrowParens": "always",
    "plugins": [
        "prettier-plugin-organize-imports"
    ]
}